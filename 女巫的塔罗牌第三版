// === NOTES ===
let notes = [];

async function loadNotes() {
  try {
    const result = await window.storage.list('note:');
    if (!result || !result.keys) {
      notes = [];
      renderNotes();
      return;
    }
    const loaded = [];
    for (const key of result.keys) {
      try {
        const r = await window.storage.get(key);
        if (r && r.value) {
          loaded.push(JSON.parse(r.value));
        }
      } catch (e) {}
    }
    notes = loaded.sort((a,b) => b.timestamp - a.timestamp);
    renderNotes();
  } catch (e) {
    console.log('Storage not available, using session memory');
    notes = [];
    renderNotes();
  }
}

function openNoteModal() {
  document.getElementById('note-modal').classList.add('open');
  document.getElementById('note-text').focus();
}

function closeNoteModal() {
  document.getElementById('note-modal').classList.remove('open');
  document.getElementById('note-text').value = '';
}

async function saveNote() {
  const text = document.getElementById('note-text').value.trim();
  if (!text) return;
  const note = {
    id: 'note:' + Date.now() + '-' + Math.random().toString(36).slice(2, 8),
    text: text,
    timestamp: Date.now(),
    date: new Date().toLocaleString('zh-CN', { dateStyle: 'medium', timeStyle: 'short' })
  };
  try {
    await window.storage.set(note.id, JSON.stringify(note));
    notes.unshift(note);
    renderNotes();
  } catch (e) {
    notes.unshift(note);
    renderNotes();
  }
  closeNoteModal();
}

async function deleteNote(id) {
  try {
    await window.storage.delete(id);
  } catch (e) {}
  notes = notes.filter(n => n.id !== id);
  renderNotes();
}

function renderNotes() {
  const display = document.getElementById('notes-display');
  if (!notes.length) {
    display.innerHTML = `<p style="text-align:center; color:var(--ash); font-style:italic; padding:30px;">— 还没有任何记录 · empty grimoire —</p>`;
    return;
  }
  display.innerHTML = notes.map(n => `
    <div class="saved-note">
      <span class="note-date">${n.date}</span>
      ${n.text.replace(/\n/g, '<br>')}
      <button class="delete-note" onclick="deleteNote('${n.id}')" title="delete">✕</button>
    </div>
  `).join('');
}

