<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Grimoire · 档案</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Ma+Shan+Zheng&family=Noto+Serif+SC:wght@300;400;500;600&display=swap');

/* Reset and Core Styles */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

:root {
  /* Witch's Lair Aesthetic - Parchment-like base with rich, soft colors and prominent gold */
  --ink: #333333; /* Soft charcoal for main text on creamy background */
  --parchment: #ebe0c8; /* Creamy off-white for main background */
  --blood: #a63f44; /* Soft Terracotta red/muted blood, based on Terracotta hues in image_2.png */
  --moss: #6d7762; /* Soft Sage green, based on Sage hues in image_3.png */
  --gold: #d4af37; /* Brighter, richer gold for prominent golden line-art borders */
  --bruise: #dcd9d4; /* Light grey for subtle shadows on cream background */
  --ash: #8b8b8b; /* Medium grey for epigraphs on cream background */
  --ember: #d98c6c; /* Softer, richer Terracotta orange for card "Meaning" highlights */
  
  /* Container and Section Borders with prominent gold line-art */
  --border-style: 2px solid var(--gold);
}

body {
  background: var(--parchment);
  color: var(--ink);
  font-family: 'Cormorant Garamond', 'Noto Serif SC', serif;
  min-height: 100vh;
  overflow-x: hidden;
  position: relative;
  line-height: 1.6;
}

/* Updated Background - Richer 'Witch's Domain' atmosphere with soft colored layers on creamy parchment */
.cosmos {
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  background:
    radial-gradient(ellipse at 20% 30%, rgba(200, 160, 200, 0.15) 0%, transparent 50%), /* Soft purple based on image_2.png left-bottom */
    radial-gradient(ellipse at 80% 70%, rgba(100, 130, 110, 0.2) 0%, transparent 60%), /* Soft green/sage based on image_3.png right-bottom */
    radial-gradient(ellipse at 50% 50%, rgba(235, 224, 200, 0.1) 0%, transparent 70%), /* Parchment glow */
    linear-gradient(180deg, #ebe0c8 0%, #ebe0c8 100%); /* Main creamy parchment background */
}

/* Golden stars, coordinate color to new gold variable */
.stars {
  position: fixed;
  inset: 0;
  z-index: 1;
  pointer-events: none;
}

.star {
  position: absolute;
  width: 2.5px;
  height: 2.5px;
  background: var(--gold);
  border-radius: 50%;
  animation: twinkle var(--dur, 4s) ease-in-out infinite;
  opacity: 0;
}

@keyframes twinkle {
  0%, 100% { opacity: 0; transform: scale(0.5); }
  50% { opacity: 0.9; transform: scale(1.1); }
}

/* Smoke - coordinated colors to new background and variables */
.smoke {
  position: fixed;
  inset: 0;
  z-index: 1;
  pointer-events: none;
  background:
    radial-gradient(circle at 30% 20%, rgba(200, 160, 200, 0.05) 0%, transparent 40%), /* Subtle purple smoke */
    radial-gradient(circle at 70% 80%, rgba(100, 130, 110, 0.06) 0%, transparent 40%); /* Subtle sage smoke */
  animation: drift 30s ease-in-out infinite;
}

@keyframes drift {
  0%, 100% { transform: translate(0, 0); }
  50% { transform: translate(20px, -20px); }
}

/* Main container */
.grimoire {
  position: relative;
  z-index: 2;
  max-width: 1400px;
  margin: 0 auto;
  padding: 60px 30px;
}

/* Header - More prominent golden lines and ornate feel */
.cover {
  text-align: center;
  padding: 60px 20px 40px;
  position: relative;
  border-bottom: 2px solid var(--gold); /* Golden line border */
}

.sigil {
  font-family: 'Cinzel', serif;
  font-size: 13px;
  letter-spacing: 6px;
  color: var(--ink);
  text-transform: uppercase;
  margin-bottom: 20px;
  opacity: 0.8;
}

.title-mark {
  display: inline-block;
  font-size: 36px;
  color: var(--gold); /* Clear gold color for symbols */
  margin: 10px 0 15px;
  filter: drop-shadow(0 0 10px rgba(212, 175, 55, 0.3)); /* Clear gold shadow */
}

.title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(36px, 6vw, 64px);
  font-weight: 600;
  letter-spacing: 2px;
  color: var(--ink); /* Main dark text on cream background */
  background: none; /* Removed dark gradient from original */
  -webkit-background-clip: unset;
  background-clip: unset;
  -webkit-text-fill-color: unset;
  margin-bottom: 15px;
  text-shadow: 0 0 10px rgba(212, 175, 55, 0.2); /* Subtle gold text shadow */
}

.title-cn {
  font-family: 'Ma Shan Zheng', 'Noto Serif SC', serif;
  font-size: clamp(20px, 3vw, 28px);
  color: var(--ink); /* Main dark text on cream background */
  letter-spacing: 4px;
  margin-bottom: 25px;
}

.epigraph {
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  font-size: 17px;
  max-width: 650px;
  margin: 0 auto;
  color: var(--ash); /* Clearer text on cream background */
  line-height: 1.7;
  padding: 25px 0;
  border-top: 1px solid rgba(212, 175, 55, 0.3); /* Subtle golden line borders for epigraph */
  border-bottom: 1px solid rgba(212, 175, 55, 0.3);
}

.epigraph .author {
  display: block;
  margin-top: 12px;
  font-size: 13px;
  letter-spacing: 2px;
  color: var(--gold); /* Golden highlight for author */
  font-style: normal;
}

/* Navigation - Update to match new palette with golden highlights */
.spell-nav {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 12px;
  margin: 40px 0;
  padding: 20px 0;
}

.spell-nav button {
  background: transparent;
  border: 1px solid rgba(212, 175, 55, 0.4); /* Subtler golden line borders */
  color: var(--ink); /* Main text color */
  padding: 10px 20px;
  font-family: 'Cormorant Garamond', serif;
  font-size: 13px;
  letter-spacing: 2px;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  border-radius: 2px;
}

.spell-nav button:hover {
  border-color: var(--gold); /* Clear gold border on hover */
  color: var(--gold); /* Golden text highlight */
  background: rgba(212, 175, 55, 0.05); /* Subtle gold background highlight */
  transform: translateY(-1px);
  box-shadow: 0 3px 15px rgba(212, 175, 55, 0.15); /* Subtler gold shadow */
}

.spell-nav button.active {
  border-color: var(--blood); /* terracotta red for active state */
  color: var(--ember); /* Terracotta orange for active text, based on hues in image_2.png */
  background: rgba(166, 63, 68, 0.06); /* terracotta background highlight */
  font-weight: 500;
}

/* Act-wide Container Borders - prominent golden lines for each Act section */
.section-content {
  display: none;
  border: var(--border-style); /* Prominent gold line border for entire Act section */
  padding: 40px;
  margin-bottom: 40px;
  background: rgba(235, 224, 200, 0.6); /* Semi-opaque parchment background for content area */
  border-radius: 8px; /* Slightly rounded Act sections */
}

.section-content.active {
  display: block;
}

/* Section heading - prominent gold and clearer text on cream */
.act-heading {
  text-align: center;
  margin: 60px 0 40px;
  position: relative;
}

.act-number {
  font-family: 'Cinzel', serif;
  font-size: 11px;
  letter-spacing: 4px;
  color: var(--gold); /* Golden act numbers */
  text-transform: uppercase;
  opacity: 0.7;
}

.act-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 32px;
  color: var(--ink); /* Clear text color on cream background */
  margin-top: 10px;
  letter-spacing: 2px;
  font-weight: 600;
}

.act-title-cn {
  font-family: 'Noto Serif SC', serif;
  font-size: 16px;
  color: var(--ash); /* Clearer text on cream background */
  margin-top: 8px;
  letter-spacing: 3px;
  font-weight: 300;
}

.divider-ornament {
  text-align: center;
  margin: 30px 0;
  color: var(--gold); /* Clear golden color for separators */
  font-size: 18px;
  opacity: 0.6;
  letter-spacing: 20px;
}

/* Tarot card grid - clear borders and text on cream */
.tarot-spread {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 25px;
  margin: 30px 0;
}

.tarot-card {
  position: relative;
  aspect-ratio: 2 / 3.2;
  perspective: 1500px;
  cursor: pointer;
  border: 1px solid rgba(212, 175, 55, 0.3); /* Subtle golden line borders for cards */
  transition: transform 0.3s ease, border-color 0.3s ease;
  border-radius: 4px; /* Slightly rounded cards */
}

.tarot-card:hover {
  transform: translateY(-4px);
  border-color: var(--gold); /* Prominent gold border on hover */
}

.card-inner {
  position: relative;
  width: 100%;
  height: 100%;
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  transform-style: preserve-3d;
  border-radius: 4px; /* Slightly rounded internal card inner */
}

.tarot-card.flipped .card-inner {
  transform: rotateY(180deg);
}

.card-face {
  position: absolute;
  inset: 0;
  backface-visibility: hidden;
  border-radius: 4px; /* Slightly rounded internal card face */
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* Card back - Ornate pattern based on image_4.png - image_10.png, using rich soft colors and gold lines on cream */
.card-back {
  background: var(--parchment); /* Base parchment on card back */
  padding: 30px 20px;
  align-items: center;
  justify-content: space-between;
  text-align: center;
}

.card-back::before {
  content: '';
  position: absolute;
  inset: 6px;
  border: 1px solid rgba(212, 175, 55, 0.2); /* Subtler golden line border inner on card back */
  border-radius: 2px;
  pointer-events: none;
}

/* Roma numerals use Cinzel for classical feel */
.card-roman {
  font-family: 'Cinzel', serif;
  font-size: 12px;
  letter-spacing: 3px;
  color: var(--gold); /* Golden Roma numbers */
  margin-top: 10px;
}

/* The symbol element gets a subtle ornate pattern based on image_6.png (soft moon pattern on cream) */
.card-symbol {
  font-size: 70px;
  color: var(--ink); /* Clear ink color on cream background */
  margin: auto 0;
  animation: pulseLight 4s ease-in-out infinite;
}

@keyframes pulseLight {
  0%, 100% { opacity: 0.9; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.02); }
}

/* Arcana name uses Cinzel for classical feel */
.card-arcana-name {
  font-family: 'Cinzel', serif;
  font-size: 15px;
  letter-spacing: 3px;
  color: var(--ink); /* Main dark text on cream background */
  text-transform: uppercase;
  font-weight: 500;
}

.card-arcana-name-cn {
  font-family: 'Ma Shan Zheng', 'Noto Serif SC', serif;
  font-size: 13px;
  color: var(--ash); /* Clearer text on cream background */
  letter-spacing: 2px;
  margin-top: 4px;
}

.card-hint {
  font-size: 10px;
  color: var(--ash); /* Clearer text on cream background */
  letter-spacing: 1px;
  font-style: italic;
  margin-top: 12px;
}

/* Card front (event) - prominent golden border inner and text on cream */
.card-front {
  background: var(--parchment); /* Base parchment on card front */
  transform: rotateY(180deg);
  padding: 22px 20px;
  overflow-y: auto;
  border: 2px solid var(--gold); /* Prominent gold line-art inner border on card front */
}

.card-front::before {
  content: '';
  position: absolute;
  inset: 4px;
  border: 1px solid rgba(212, 175, 55, 0.15); /* Subtler golden line border inner on card front */
  border-radius: 2px;
  pointer-events: none;
}

.card-event-date {
  font-family: 'Cormorant Garamond', serif;
  font-size: 10px;
  letter-spacing: 2px;
  color: var(--ink); /* Main dark text on cream background */
  margin-bottom: 6px;
  opacity: 0.7;
}

.card-event-title {
  font-family: 'Noto Serif SC', serif;
  font-size: 16px;
  color: var(--ink); /* Main dark text on cream background */
  margin-bottom: 10px;
  font-weight: 600;
  line-height: 1.4;
}

.card-event-body {
  font-family: 'Noto Serif SC', serif;
  font-size: 12px;
  line-height: 1.7;
  color: rgba(51, 51, 51, 0.9); /* Clear text on cream background */
  margin-bottom: 12px;
  font-weight: 300;
}

.card-event-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
  margin-top: auto;
  padding-top: 10px;
  border-top: 1px solid rgba(212, 175, 55, 0.15); /* Subtler golden line border separating tags */
}

.event-tag {
  font-family: 'Cormorant Garamond', serif;
  font-size: 9px;
  letter-spacing: 1px;
  padding: 3px 6px;
  border: 1px solid rgba(212, 175, 55, 0.3); /* Subtle golden line border for each tag */
  color: var(--ink); /* Tag text color */
  border-radius: 1px;
  text-transform: uppercase;
}

.card-event-meaning {
  font-style: italic;
  font-family: 'Cormorant Garamond', serif;
  font-size: 12px;
  color: var(--ember); /* Terracotta orange highlight for 'Meaning' text */
  margin-top: 8px;
  padding: 8px;
  background: rgba(217, 140, 108, 0.05); /* Subtle Terracotta background highlight, based on image_2.png */
  border-left: 2px solid var(--ember); /* Terracotta orange border highlight */
}

/* Threads section - prominent gold lines and clearer text on cream */
.threads {
  margin: 50px 0;
}

.thread {
  background: var(--parchment); /* Base parchment on each Thread section */
  border: 1px solid rgba(212, 175, 55, 0.3); /* Subtle golden line borders for threads */
  padding: 30px;
  margin-bottom: 20px;
  position: relative;
  cursor: pointer;
  transition: all 0.3s ease;
  border-radius: 3px; /* Slightly rounded threads */
}

.thread::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 3px;
  height: 100%;
  background: linear-gradient(180deg, transparent, var(--gold), transparent);
  opacity: 0.5;
  transition: opacity 0.3s ease;
}

.thread:hover {
  border-color: var(--gold); /* Clear gold border on hover */
  transform: translateX(4px);
  background: rgba(212, 175, 55, 0.03); /* Subtle gold background highlight */
}

.thread:hover::before {
  opacity: 1;
}

.thread-glyph {
  font-family: 'Cinzel', serif;
  font-size: 10px;
  letter-spacing: 3px;
  color: var(--ink); /* Main dark text color on cream background */
  margin-bottom: 10px;
  opacity: 0.8;
}

.thread-title {
  font-family: 'Noto Serif SC', serif;
  font-size: 20px;
  color: var(--ink); /* Main dark text on cream background */
  margin-bottom: 12px;
  font-weight: 500;
}

.thread-body {
  font-family: 'Noto Serif SC', serif;
  font-size: 14px;
  line-height: 1.8;
  color: rgba(51, 51, 51, 0.9); /* Clear text on cream background */
}

.thread-cards {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 15px;
}

/* Card reference links use Cormorant Garamond for典雅典雅 feel */
.thread-card-ref {
  font-family: 'Cormorant Garamond', serif;
  font-size: 10px;
  letter-spacing: 1px;
  padding: 3px 8px;
  background: rgba(212, 175, 55, 0.03); /* Subtle gold background highlight */
  border: 1px solid rgba(212, 175, 55, 0.3); /* Subtle golden line border separating tag links */
  color: var(--ink); /* Tag link text color */
  border-radius: 1px;
}

/* Inspiration vault - prominent gold lines and clearer text on cream */
.vault {
  background: var(--parchment); /* Base parchment background */
  border: 2px solid var(--gold); /* Prominent gold line-art outer border on vault section */
  padding: 40px 30px;
  margin: 50px 0;
  position: relative;
  border-radius: 4px; /* Slightly rounded vault section */
}

.vault::before, .vault::after {
  content: '✦';
  position: absolute;
  font-size: 18px;
  color: var(--gold); /* Clear golden color for separator ornaments */
  opacity: 0.6;
}

.vault::before { top: -10px; left: 30px; background: var(--parchment); padding: 0 8px; }
.vault::after { bottom: -10px; right: 30px; background: var(--parchment); padding: 0 8px; }

.vault-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 25px;
  margin-top: 25px;
}

.spell {
  border: 1px solid rgba(212, 175, 55, 0.2); /* Subtle golden line border for each spell card */
  padding: 22px;
  background: var(--parchment); /* Base parchment for each spell card area */
  transition: all 0.3s ease;
  position: relative;
  border-radius: 2px; /* Slightly rounded spells */
}

.spell:hover {
  border-color: var(--gold); /* Clear gold border on hover */
  background: rgba(212, 175, 55, 0.03); /* Subtle gold background highlight */
  transform: scale(1.01);
}

.spell-rune {
  font-size: 24px;
  color: var(--ink); /* Clear ink color on cream background */
  margin-bottom: 12px;
  display: block;
}

/* Spell name uses Cormorant Garamond for典雅典雅 feel */
.spell-name {
  font-family: 'Cormorant Garamond', serif;
  font-size: 12px;
  letter-spacing: 2px;
  color: var(--ink); /* Main dark text on cream background */
  text-transform: uppercase;
  font-weight: 500;
}

.spell-name-cn {
  font-family: 'Noto Serif SC', serif;
  font-size: 16px;
  color: var(--ink); /* Main dark text on cream background */
  margin-bottom: 10px;
  font-weight: 500;
}

.spell-desc {
  font-family: 'Noto Serif SC', serif;
  font-size: 13px;
  line-height: 1.7;
  color: rgba(51, 51, 51, 0.85); /* Clear text on cream background */
}

/* Reading area - prominent gold lines and clearer text on cream */
.reading-altar {
  margin: 60px 0;
  text-align: center;
  padding: 50px 20px;
  background: var(--parchment); /* Base parchment background */
  border: 2px solid var(--gold); /* Prominent gold line-art border on altar section */
  border-radius: 4px; /* Slightly rounded altar */
}

.altar-title {
  font-family: 'Cinzel', serif;
  font-size: 13px;
  letter-spacing: 5px;
  color: var(--ink); /* Main dark text color on cream background */
  margin-bottom: 25px;
}

.draw-button {
  background: transparent;
  border: 1px solid var(--gold); /* Clear golden line borders for buttons */
  color: var(--gold); /* Golden button text highlight */
  padding: 15px 40px;
  font-family: 'Cormorant Garamond', serif;
  font-size: 13px;
  letter-spacing: 3px;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  border-radius: 2px;
}

.draw-button:hover {
  background: var(--gold); /* Gold background on hover */
  color: var(--parchment); /* Creamy parchment text on hover */
  letter-spacing: 4px;
  box-shadow: 0 0 20px rgba(212, 175, 55, 0.2); /* Subtle gold text shadow and box shadow */
}

.drawn-card-display {
  margin-top: 35px;
  min-height: 180px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.drawn-message {
  max-width: 550px;
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  font-size: 19px;
  line-height: 1.7;
  color: var(--ink); /* Clear text on cream background */
  padding: 25px;
  border: 1px solid rgba(212, 175, 55, 0.4); /* Subtler golden line borderinner display */
  background: var(--parchment); /* Base parchment inner display area */
  position: relative;
  animation: fadeUpMinimal 0.7s ease;
  border-radius: 3px; /* Slightly rounded display inner */
}

.drawn-message::before, .drawn-message::after {
  content: '”';
  font-family: 'Cinzel', serif;
  font-size: 50px;
  color: var(--gold); /* Clear golden color for separators/quotes */
  opacity: 0.4;
  position: absolute;
  line-height: 1;
}
.drawn-message::before { top: 8px; left: 12px; }
.drawn-message::after { bottom: -18px; right: 12px; }

@keyframes fadeUpMinimal {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

/* Card reference links in message use Cinzel for古典典雅 feel */
.drawn-attribution {
  display: block;
  margin-top: 15px;
  font-style: normal;
  font-family: 'Cinzel', serif;
  font-size: 11px;
  letter-spacing: 2px;
  color: var(--ink); /* Main dark text color on cream background */
  text-transform: uppercase;
  opacity: 0.7;
}

/* Footer - prominent gold lines and clearer text on cream */
.colophon {
  text-align: center;
  padding: 50px 20px 30px;
  border-top: 1px solid var(--gold); /* prominent golden line borderseparator页脚页脚 separation separationseparation页脚 separation separation séparation séparationseparation séparation séparation separación separation séparación séparation separation separation separator separar */
  margin-top: 60px;
}

.colophon-text {
  font-family: 'Cormorant Garamond', serif;
  font-style: italic;
  font-size: 15px;
  color: var(--ash); /* Clearer text on cream background */
  max-width: 550px;
  margin: 0 auto 18px;
  line-height: 1.7;
}

/* Card reference link in colophon colophon colophon uses Cormorant Garamond colophon uses Cormorant Garamond uses Cormorant Garamond for古典典雅古典 feel */
.colophon-mark {
  color: var(--ink); /* Main dark text color on cream background */
  letter-spacing: 3px;
  font-family: 'Cormorant Garamond', serif;
  font-size: 11px;
  opacity: 0.8;
}

/* Update section visible transitions minimal minimal fadeIn fade fadeMin fadeInMin fadeInMinimal fadeIn Minimal transitionsMinimal transitions minimal */
@keyframes fadeInMinimal {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}

/* Update add-note add-note with gold gold lines and text on clear black add black black clear black clear black clear add-note add-note gold gold clear clear black black add-note add-note gold gold black black black add-note add-note add-note add-note add-note add-note add-note add-note add-note add-note add-note */
.add-note {
  position: fixed;
  bottom: 25px;
  right: 25px;
  width: 50px;
  height: 50px;
  border-radius: 50%;
  background: var(--ink); /* Clear ink/dark background */
  border: 1px solid var(--gold); /* prominent golden line borders for floating button */
  color: var(--gold); /* Golden icon highlight for floating button highlightfloating button floating button icon */
  font-size: 20px;
  cursor: pointer;
  z-index: 100;
  transition: all 0.3s ease;
  box-shadow: 0 3px 15px rgba(0,0,0,0.15); /* Subtler gold and black black shadow black black black shadow black shadow shadow black black shadow black shadow */
